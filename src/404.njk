---
layout: layouts/base.njk
lang: en
pageKey: notFound
permalink: /404.html
---
{% set t = i18n[lang] %}
{% set p = t.pages.notFound %}
{% set meta = p.meta %}

<div class="bg-grid">
  <header class="sticky top-0 z-50 border-b border-slate-900/10 bg-white/70 backdrop-blur">
    <div class="container mx-auto px-4">
      <div class="flex h-16 items-center justify-between gap-4">
        <a class="flex items-center gap-2" href="/" aria-label="Home"><img class="h-9 w-9 rounded-xl" src="/icon.svg" alt="{{ site.name }}" /><span class="font-semibold tracking-tight">{{ site.name }}</span></a>
        <nav class="hidden md:flex items-center gap-6 text-sm">
          <a class="hover:text-slate-950 text-slate-700" href="/features">{{ t.nav.features }}</a>
          <a class="hover:text-slate-950 text-slate-700" href="/pricing">{{ t.nav.pricing }}</a>
          <a class="hover:text-slate-950 text-slate-700" href="/privacy">{{ t.nav.privacy }}</a>
          <a class="hover:text-slate-950 text-slate-700" href="/support">{{ t.nav.support }}</a>
        </nav>
        <div class="flex items-center gap-2">
          <a class="hidden sm:inline-flex rounded-xl px-3 py-2 text-sm font-medium text-slate-700 hover:bg-slate-900/5" href="{{ site.gumroadUrl }}" target="_blank" rel="noreferrer">{{ t.nav.upgrade }}</a>
          <a class="inline-flex items-center justify-center rounded-xl bg-slate-900 px-4 py-2 text-sm font-semibold text-white hover:bg-slate-800" href="{{ site.chromeStoreUrl }}" target="_blank" rel="noreferrer">{{ t.nav.addToChrome }}</a>
        </div>
      </div>
    </div>
  </header>

  <main class="container mx-auto px-4 py-14">
    <div class="max-w-2xl">
      <div class="inline-flex items-center gap-2 rounded-full px-3 py-1 text-xs badge text-slate-700">
        <span class="h-2 w-2 rounded-full bg-amber-500"></span>
        <span>{{ p.badge }}</span>
      </div>

      <h1 class="mt-5 text-3xl md:text-4xl font-semibold tracking-tight">{{ p.h1 }}</h1>
      <p class="mt-3 text-slate-700">{{ p.body }}</p>

      <div class="mt-8 grid gap-3 sm:grid-cols-2">
        {% for card in p.cards %}
        <a class="rounded-2xl p-5 card shadow-soft hover:bg-white" href="{{ card.href }}">
          <div class="text-sm font-semibold">{{ card.heading }}</div>
          <div class="mt-1 text-sm text-slate-600">{{ card.sub }}</div>
        </a>
        {% endfor %}
      </div>

      <div class="mt-8">
        <a class="text-sm font-semibold text-slate-900 hover:underline" href="/">{{ p.backToHome }}</a>
      </div>
    </div>
  </main>
</div>
