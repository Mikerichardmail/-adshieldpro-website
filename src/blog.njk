---
layout: layouts/base.njk
title: "AdShield Pro Blog — Privacy & Security Insights"
description: "Insights, guides, and tips on blocking ads, stopping trackers, and browsing safely from the AdShield Pro Team."
permalink: /blog/index.html
---
{% set t = i18n[lang] | default(i18n.en) %}
<div class="bg-grid">
  <header class="sticky top-0 z-50 border-b border-slate-900/10 bg-white/70 backdrop-blur">
    <div class="container mx-auto px-4">
      <div class="flex h-16 items-center justify-between gap-4">
        <a class="flex items-center gap-2" href="/" aria-label="Home"><img class="h-9 w-9 rounded-xl" src="/icon.svg" alt="{{ site.name }}" /><span class="font-semibold tracking-tight">{{ site.name }}</span></a>
        <nav class="hidden md:flex items-center gap-6 text-sm">
          <a class="hover:text-slate-950 text-slate-700 font-medium" href="/features">{{ t.nav.features }}</a>
          <a class="hover:text-slate-950 text-slate-700 font-medium" href="/pricing">{{ t.nav.pricing }}</a>
          <a class="hover:text-slate-950 text-slate-700 font-medium" href="/blog">Blog</a>
          <a class="hover:text-slate-950 text-slate-700 font-medium" href="/privacy">{{ t.nav.privacy }}</a>
          <a class="hover:text-slate-950 text-slate-700 font-medium" href="/support">{{ t.nav.support }}</a>
        </nav>
        <div class="flex items-center gap-3">
          <a class="inline-flex items-center justify-center rounded-xl border border-slate-900/10 px-4 py-2 text-sm font-semibold text-slate-900 hover:bg-slate-50" href="{{ site.chromeStoreUrl }}" target="_blank" rel="noreferrer">{{ t.nav.addToChrome }}</a>
          <a class="inline-flex items-center justify-center rounded-xl bg-slate-900 px-4 py-2 text-sm font-semibold text-white hover:bg-slate-800" href="/pricing">Upgrade to Pro</a>
        </div>
      </div>
    </div>
  </header>

  <main class="container mx-auto px-4 py-12 md:py-16">
    <div class="max-w-5xl mx-auto">
      <!-- Title & Intro -->
      <div class="max-w-3xl">
        <p class="text-sm font-semibold text-slate-600">Privacy & Security Blog</p>
        <h1 class="mt-3 text-4xl md:text-5xl font-semibold tracking-tight text-slate-900 leading-tight">Insights, Guides & Tips</h1>
        <p class="mt-4 text-lg text-slate-700 leading-relaxed">Stay updated with the latest research on ad tracking, online surveillance, browser performance, and practical guides to protect your privacy.</p>
      </div>

      <!-- Blog Posts Grid -->
      <div class="mt-12 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {% for post in collections.posts | reverse %}
        <article class="rounded-3xl p-6 bg-white border border-slate-900/10 shadow-soft hover:shadow-md transition-shadow duration-200 flex flex-col justify-between">
          <div>
            <!-- Category & Date -->
            <div class="flex items-center gap-2 text-xs">
              <span class="inline-flex items-center gap-1.5 rounded-full px-2.5 py-0.5 badge text-slate-700 font-semibold bg-slate-100">{{ post.data.category | default("Guides") }}</span>
              <span class="text-slate-300">•</span>
              <time class="text-slate-500 font-medium" datetime="{{ post.date }}">{{ post.data.date }}</time>
            </div>
            <!-- Title -->
            <h2 class="mt-4 text-xl font-semibold text-slate-900 leading-snug">
              <a class="hover:underline" href="{{ post.url }}">{{ post.data.title }}</a>
            </h2>
            <!-- Description -->
            <p class="mt-2 text-sm text-slate-600 line-clamp-3 leading-relaxed">{{ post.data.description }}</p>
          </div>
          <div class="mt-6 pt-4 border-t border-slate-900/5 flex items-center justify-between text-xs text-slate-500 font-medium">
            <span>{{ post.data.reading_time | default("4 min read") }}</span>
            <a class="font-semibold text-slate-900 hover:underline inline-flex items-center gap-1" href="{{ post.url }}">
              Read Article <span>→</span>
            </a>
          </div>
        </article>
        {% endfor %}
      </div>
    </div>
  </main>

  {% include "partials/footer.njk" %}
</div>
