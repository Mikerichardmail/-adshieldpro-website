---
layout: layouts/base.njk
lang: en
pageKey: home
headerCtaUpgrade: true
permalink: /index.html
---
{% set t = i18n[lang] %}
{% set p = t.pages.home %}
{% set meta = p.meta %}
{% set jsonld %}
{
  "@context": "https://schema.org",
  "@graph": [
    { "@type": "Organization", "@id": "{{ site.url }}/#organization", "name": "{{ site.name }}", "url": "{{ site.url }}/", "email": "{{ site.email }}", "logo": { "@type": "ImageObject", "url": "{{ site.url }}/icon.svg" } },
    { "@type": "WebSite", "@id": "{{ site.url }}/#website", "url": "{{ site.url }}/", "name": "{{ site.name }}", "publisher": { "@id": "{{ site.url }}/#organization" } },
    { "@type": "WebPage", "@id": "{{ site.url }}/#webpage", "url": "{{ site.url }}/", "name": "{{ site.name }}", "isPartOf": { "@id": "{{ site.url }}/#website" }, "about": { "@id": "{{ site.url }}/#app" }, "publisher": { "@id": "{{ site.url }}/#organization" } },
    { "@type": "BreadcrumbList", "@id": "{{ site.url }}/#breadcrumb", "itemListElement": [{ "@type": "ListItem", "position": 1, "name": "Home", "item": "{{ site.url }}/" }] },
    { "@type": "SoftwareApplication", "@id": "{{ site.url }}/#app", "name": "{{ site.name }}", "applicationCategory": "BrowserApplication", "operatingSystem": "Chrome", "description": "Privacy-first, offline-first ad blocker that blocks ads and trackers to make browsing faster and cleaner.", "url": "{{ site.url }}/", "image": "{{ site.ogImage }}", "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD", "category": "Free" }, "publisher": { "@id": "{{ site.url }}/#organization" } },
    { "@type": "FAQPage", "mainEntity": [
      { "@type": "Question", "name": "{{ t.pages.home.faq.items[0].q }}", "acceptedAnswer": { "@type": "Answer", "text": "{{ t.pages.home.faq.items[0].a }}" } },
      { "@type": "Question", "name": "{{ t.pages.home.faq.items[1].q }}", "acceptedAnswer": { "@type": "Answer", "text": "{{ t.pages.home.faq.items[1].a }}" } },
      { "@type": "Question", "name": "{{ t.pages.home.faq.items[2].q }}", "acceptedAnswer": { "@type": "Answer", "text": "{{ t.pages.home.faq.items[2].a }}" } },
      { "@type": "Question", "name": "{{ t.pages.home.faq.items[3].q }}", "acceptedAnswer": { "@type": "Answer", "text": "{{ t.pages.home.faq.items[3].a }}" } }
    ] }
  ]
}
{% endset %}

<div class="bg-grid">
  {% include "partials/header.njk" %}

  <main>
    {# Hero #}
    <section class="relative">
      <div class="container mx-auto px-4 pt-14 pb-10 md:pt-20 md:pb-16">
        <div class="grid grid-cols-1 gap-10 md:grid-cols-2 md:items-center">
          <div>
            <div class="inline-flex items-center gap-2 rounded-full px-3 py-1 text-xs badge text-slate-700">
              <span class="h-2 w-2 rounded-full bg-emerald-500"></span>
              <span>{{ p.hero.badge }}</span>
            </div>
            <h1 class="mt-5 text-4xl font-semibold leading-tight tracking-tight md:text-5xl text-balance flex items-center gap-3">
              <img class="h-12 w-12 rounded-xl" src="/icon.svg" alt="{{ site.name }}" />
              {{ p.hero.h1 }}
            </h1>
            <p class="mt-4 text-lg text-slate-700 text-balance">{{ p.hero.intro1 }}</p>
            <p class="mt-4 text-lg text-slate-700 text-balance">{{ p.hero.intro2 }}</p>
            <p class="mt-4 text-lg text-slate-700 text-balance">{{ p.hero.intro3 }}</p>

            <div class="mt-7 flex flex-col gap-3 sm:flex-row sm:items-center">
              <a class="inline-flex items-center justify-center rounded-xl bg-slate-900 px-5 py-3 text-sm font-semibold text-white hover:bg-slate-800" href="{{ site.chromeStoreUrl }}" target="_blank" rel="noreferrer">{{ p.hero.ctaPrimary }}</a>
              <a class="inline-flex items-center justify-center rounded-xl px-5 py-3 text-sm font-semibold text-slate-900 ring-1 ring-slate-900/10 hover:bg-white" href="{{ site.gumroadUrl }}" target="_blank" rel="noreferrer">{{ p.hero.ctaSecondary }}</a>
            </div>

            <div class="mt-6 grid grid-cols-3 gap-3 text-sm">
              {% for stat in p.hero.stats %}
              <div class="rounded-xl p-3 card shadow-soft">
                <div class="font-semibold">{{ stat.label }}</div>
                <div class="text-slate-600">{{ stat.sub }}</div>
              </div>
              {% endfor %}
            </div>
          </div>

          <div class="relative">
            <div class="rounded-2xl card shadow-soft overflow-hidden">
              <div class="border-b border-slate-900/10 p-4 flex items-center justify-between">
                <div class="text-sm font-semibold">{{ p.hero.previewLabel }}</div>
                <div class="flex gap-1">
                  <div class="h-2.5 w-2.5 rounded-full bg-red-400"></div>
                  <div class="h-2.5 w-2.5 rounded-full bg-amber-400"></div>
                  <div class="h-2.5 w-2.5 rounded-full bg-emerald-400"></div>
                </div>
              </div>
              <div class="p-6">
                <div class="rounded-xl bg-white border border-slate-900/10 p-4">
                  <div class="text-sm text-slate-600">{{ p.hero.previewCaption }}</div>
                  <div class="mt-2 h-48 rounded-lg bg-white overflow-hidden p-2">
                    <img class="h-full w-full object-contain" src="/ui-image.png" alt="{{ p.hero.previewAlt }}" loading="lazy" />
                  </div>
                </div>
                <div class="mt-4 grid grid-cols-2 gap-3">
                  <div class="rounded-xl border border-slate-900/10 bg-white p-4">
                    <div class="text-sm font-semibold">{{ p.hero.previewCard1.label }}</div>
                    <div class="mt-1 text-sm text-slate-600">{{ p.hero.previewCard1.sub }}</div>
                  </div>
                  <div class="rounded-xl border border-slate-900/10 bg-white p-4">
                    <div class="text-sm font-semibold">{{ p.hero.previewCard2.label }}</div>
                    <div class="mt-1 text-sm text-slate-600">{{ p.hero.previewCard2.sub }}</div>
                  </div>
                </div>
              </div>
            </div>
            <div class="pointer-events-none absolute -z-10 -inset-10 rounded-[32px] bg-gradient-to-br from-blue-200/40 via-indigo-200/30 to-emerald-200/30 blur-2xl"></div>
          </div>
        </div>
      </div>
    </section>

    {# Explore More #}
    <section id="related" class="container mx-auto px-4 py-12 md:py-16">
      <div class="flex items-end justify-between gap-6 flex-wrap">
        <div>
          <h2 class="text-2xl md:text-3xl font-semibold tracking-tight">{{ p.related.heading }}</h2>
          <p class="mt-2 text-slate-700 max-w-3xl">{{ p.related.sub }}</p>
        </div>
      </div>
      <div class="mt-8 grid grid-cols-1 md:grid-cols-2 gap-4">
        {% for card in p.related.cards %}
        <a class="rounded-2xl p-6 card shadow-soft hover:bg-white" href="{{ card.href }}">
          <div class="text-sm font-semibold">{{ card.label }}</div>
          <p class="mt-2 text-sm text-slate-700">{{ card.desc }}</p>
        </a>
        {% endfor %}
      </div>
    </section>

    {# Block Ads #}
    <section id="features" class="container mx-auto px-4 py-12 md:py-16">
      <div class="flex items-end justify-between gap-6 flex-wrap">
        <div>
          <h2 class="text-2xl md:text-3xl font-semibold tracking-tight">{{ p.blockAds.h2 }}</h2>
          <p class="mt-2 text-slate-700 max-w-3xl">{{ p.blockAds.intro }}</p>
        </div>
        <a class="text-sm font-semibold text-slate-900 hover:underline" href="/features">{{ p.blockAds.seeAll }}</a>
      </div>
      <div class="mt-8 grid grid-cols-1 md:grid-cols-2 gap-4">
        <div class="rounded-2xl p-6 card shadow-soft">
          <div class="text-sm font-semibold">{{ p.blockAds.card1Heading }}</div>
          <ul class="mt-3 grid gap-2 text-sm text-slate-700 list-disc pl-5">
            {% for item in p.blockAds.card1Items %}<li>{{ item }}</li>{% endfor %}
          </ul>
        </div>
        <div class="rounded-2xl p-6 card shadow-soft">
          <div class="text-sm font-semibold">{{ p.blockAds.card2Heading }}</div>
          <p class="mt-2 text-sm text-slate-700">{{ p.blockAds.card2Body }}</p>
        </div>
      </div>
    </section>

    {# Stop Trackers #}
    <section id="privacy" class="container mx-auto px-4 py-12 md:py-16">
      <div class="rounded-3xl p-6 md:p-10 bg-white border border-slate-900/10 shadow-soft">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          <div>
            <h2 class="text-2xl md:text-3xl font-semibold tracking-tight">{{ p.stopTrackers.h2 }}</h2>
            <p class="mt-2 text-slate-700">{{ p.stopTrackers.intro }}</p>
          </div>
          <div class="md:col-span-2 grid grid-cols-1 sm:grid-cols-3 gap-4">
            {% for f in p.stopTrackers.features %}
            <div class="rounded-2xl p-5 bg-slate-50 border border-slate-900/10">
              <div class="text-xs font-semibold text-slate-600">{{ f.icon }}</div>
              <div class="mt-2 font-semibold">{{ f.heading }}</div>
              <p class="mt-1 text-sm text-slate-700">{{ f.body }}</p>
            </div>
            {% endfor %}
          </div>
        </div>
        <p class="mt-6 text-slate-700">{{ p.stopTrackers.outro1 }}</p>
        <p class="mt-3 text-slate-700">{{ p.stopTrackers.outro2 }} <a class="font-semibold text-slate-900 hover:underline" href="/privacy">{{ p.stopTrackers.privacyLinkText }}</a>.</p>
      </div>
    </section>

    {# Faster Browsing #}
    <section id="speed" class="container mx-auto px-4 py-12 md:py-16">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 items-stretch">
        <div class="rounded-3xl p-8 card shadow-soft">
          <h2 class="text-2xl font-semibold tracking-tight">{{ p.faster.h2 }}</h2>
          <p class="mt-2 text-slate-700">{{ p.faster.intro }}</p>
          <p class="mt-4 text-slate-700">{{ p.faster.body }}</p>
        </div>
        <div class="rounded-3xl p-8 bg-white border border-slate-900/10 shadow-soft">
          <h3 class="text-lg font-semibold">{{ p.faster.withProHeading }}</h3>
          <div class="mt-4 grid gap-3 text-sm text-slate-700">
            {% for b in p.faster.benefits %}
            <div class="flex gap-3"><span class="mt-0.5 h-5 w-5 rounded-full bg-emerald-100 text-emerald-700 grid place-items-center text-xs">✓</span><span>{{ b }}</span></div>
            {% endfor %}
          </div>
        </div>
      </div>
    </section>

    {# Simple Yet Powerful #}
    <section id="simple" class="container mx-auto px-4 py-12 md:py-16">
      <div class="rounded-3xl p-6 md:p-10 bg-white border border-slate-900/10 shadow-soft">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          <div>
            <h2 class="text-2xl md:text-3xl font-semibold tracking-tight">{{ p.simple.h2 }}</h2>
            <p class="mt-2 text-slate-700">{{ p.simple.intro }}</p>
          </div>
          <div class="md:col-span-2 grid grid-cols-1 sm:grid-cols-3 gap-4">
            {% for f in p.simple.features %}
            <div class="rounded-2xl p-5 bg-slate-50 border border-slate-900/10">
              <div class="text-xs font-semibold text-slate-600">{{ f.icon }}</div>
              <div class="mt-2 font-semibold">{{ f.heading }}</div>
              {% if f.items %}
              <ul class="mt-2 grid gap-2 text-sm text-slate-700 list-disc pl-5">
                {% for item in f.items %}<li>{{ item }}</li>{% endfor %}
              </ul>
              {% else %}
              <p class="mt-1 text-sm text-slate-700">{{ f.body }}</p>
              {% endif %}
            </div>
            {% endfor %}
          </div>
        </div>
      </div>
    </section>

    {# Why Choose #}
    <section id="why" class="container mx-auto px-4 py-12 md:py-16">
      <div class="flex items-end justify-between gap-6 flex-wrap">
        <div>
          <h2 class="text-2xl md:text-3xl font-semibold tracking-tight">{{ p.why.h2 }}</h2>
          <p class="mt-2 text-slate-700 max-w-3xl">{{ p.why.intro }}</p>
        </div>
      </div>
      <div class="mt-8 grid grid-cols-1 md:grid-cols-2 gap-4">
        {% for r in p.why.reasons %}
        <div class="rounded-2xl p-6 card shadow-soft{% if r.wide %} md:col-span-2{% endif %}">
          <div class="text-sm font-semibold">{{ r.heading }}</div>
          <p class="mt-2 text-sm text-slate-700">{{ r.body }}</p>
        </div>
        {% endfor %}
      </div>
    </section>

    {# Pro Features #}
    <section id="pro" class="container mx-auto px-4 py-12 md:py-16">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 items-stretch">
        <div class="rounded-3xl p-8 card shadow-soft">
          <h2 class="text-2xl font-semibold tracking-tight">{{ p.pro.h2 }}</h2>
          <p class="mt-2 text-slate-700">{{ p.pro.intro }}</p>
          <p class="mt-4 text-slate-700">{{ p.pro.body }}</p>
          <p class="mt-4 text-slate-700">See <a class="font-semibold text-slate-900 hover:underline" href="/pricing">{{ p.pro.pricingLink }}</a>.</p>
        </div>
        <div class="rounded-3xl p-8 bg-white border border-slate-900/10 shadow-soft">
          <div class="mt-1 grid gap-3 text-sm text-slate-700">
            {% for item in p.pro.items %}
            <div class="rounded-2xl p-5 bg-slate-50 border border-slate-900/10">
              <div class="font-semibold">{{ item.heading }}</div>
              <p class="mt-1">{{ item.body }}</p>
            </div>
            {% endfor %}
          </div>
          <a class="mt-6 inline-flex w-full items-center justify-center rounded-xl px-5 py-3 text-sm font-semibold text-slate-900 ring-1 ring-slate-900/10 hover:bg-white" href="{{ site.gumroadUrl }}" target="_blank" rel="noreferrer">{{ p.pro.cta }}</a>
        </div>
      </div>
    </section>

    {# How It Works #}
    <section id="how" class="container mx-auto px-4 py-12 md:py-16">
      <div class="rounded-3xl p-6 md:p-10 bg-white border border-slate-900/10 shadow-soft">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          <div>
            <h2 class="text-2xl md:text-3xl font-semibold tracking-tight">{{ p.howItWorks.h2 }}</h2>
            <p class="mt-2 text-slate-700">{{ p.howItWorks.intro }}</p>
          </div>
          <div class="md:col-span-2 grid grid-cols-1 sm:grid-cols-3 gap-4">
            {% for f in p.howItWorks.features %}
            <div class="rounded-2xl p-5 bg-slate-50 border border-slate-900/10">
              <div class="text-xs font-semibold text-slate-600">{{ f.icon }}</div>
              <div class="mt-2 font-semibold">{{ f.heading }}</div>
              {% if f.items %}
              <ul class="mt-2 grid gap-2 text-sm text-slate-700 list-disc pl-5">{% for item in f.items %}<li>{{ item }}</li>{% endfor %}</ul>
              {% else %}
              <p class="mt-1 text-sm text-slate-700">{{ f.body }}</p>
              {% endif %}
            </div>
            {% endfor %}
          </div>
        </div>
        <p class="mt-6 text-slate-700">{{ p.howItWorks.outro }}</p>
      </div>
    </section>

    {# Benefits #}
    <section id="benefits" class="container mx-auto px-4 py-12 md:py-16">
      <div class="flex items-end justify-between gap-6 flex-wrap">
        <div>
          <h2 class="text-2xl md:text-3xl font-semibold tracking-tight">{{ p.benefits.h2 }}</h2>
          <p class="mt-2 text-slate-700 max-w-3xl">{{ p.benefits.intro }}</p>
        </div>
      </div>
      <div class="mt-8 grid grid-cols-1 md:grid-cols-3 gap-4">
        {% for card in p.benefits.cards | slice(3) | first %}
        <div class="rounded-2xl p-6 card shadow-soft">
          <div class="text-sm font-semibold">{{ card.heading }}</div>
          <p class="mt-2 text-sm text-slate-700">{{ card.body }}</p>
        </div>
        {% endfor %}
      </div>
      <div class="mt-4 grid grid-cols-1 md:grid-cols-2 gap-4">
        {% for card in p.benefits.cards | slice(3) %}
        <div class="rounded-2xl p-6 card shadow-soft">
          <div class="text-sm font-semibold">{{ card.heading }}</div>
          <p class="mt-2 text-sm text-slate-700">{{ card.body }}</p>
        </div>
        {% endfor %}
      </div>
    </section>

    {# Browsers #}
    <section id="browsers" class="container mx-auto px-4 py-12 md:py-16">
      <div class="rounded-3xl p-6 md:p-10 bg-white border border-slate-900/10 shadow-soft">
        <h2 class="text-2xl md:text-3xl font-semibold tracking-tight">{{ p.browsers.h2 }}</h2>
        <p class="mt-2 text-slate-700">{{ p.browsers.intro }}</p>
        <div class="mt-6 grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-4 text-sm text-slate-700">
          {% for b in p.browsers.list %}
          <div class="rounded-2xl p-5 bg-slate-50 border border-slate-900/10">{{ b }}</div>
          {% endfor %}
        </div>
        <p class="mt-6 text-slate-700">{{ p.browsers.outro1 }}</p>
        <p class="mt-3 text-slate-700">{{ p.browsers.outro2 }}</p>
      </div>
    </section>

    {# Audience #}
    <section id="audience" class="container mx-auto px-4 py-12 md:py-16">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 items-stretch">
        <div class="rounded-3xl p-8 card shadow-soft">
          <h2 class="text-2xl font-semibold tracking-tight">{{ p.audience.h2 }}</h2>
          <p class="mt-2 text-slate-700">{{ p.audience.intro }}</p>
          <div class="mt-6 grid gap-3 text-slate-700">
            {% for tier in p.audience.tiers %}
            <div class="rounded-2xl p-5 bg-white border border-slate-900/10">
              <div class="font-semibold">{{ tier.heading }}</div>
              <div class="mt-1 text-sm text-slate-600">{{ tier.body }}</div>
            </div>
            {% endfor %}
          </div>
          <p class="mt-6 text-slate-700">{{ p.audience.outro }}</p>
        </div>
        <div class="rounded-3xl p-8 bg-white border border-slate-900/10 shadow-soft">
          <h3 class="text-lg font-semibold">{{ p.audience.gettingStarted.heading }}</h3>
          <p class="mt-2 text-sm text-slate-700">{{ p.audience.gettingStarted.intro }}</p>
          <ol class="mt-4 grid gap-2 text-sm text-slate-700 list-decimal pl-5">
            {% for step in p.audience.gettingStarted.steps %}<li>{{ step }}</li>{% endfor %}
          </ol>
          <p class="mt-4 text-sm text-slate-700">{{ p.audience.gettingStarted.outro }}</p>
          <div class="mt-6 flex flex-col sm:flex-row gap-3">
            <a class="inline-flex w-full items-center justify-center rounded-xl bg-slate-900 px-5 py-3 text-sm font-semibold text-white hover:bg-slate-800" href="{{ site.chromeStoreUrl }}" target="_blank" rel="noreferrer">{{ p.audience.gettingStarted.ctaPrimary }}</a>
            <a class="inline-flex w-full items-center justify-center rounded-xl px-5 py-3 text-sm font-semibold text-slate-900 ring-1 ring-slate-900/10 hover:bg-white" href="{{ site.gumroadUrl }}" target="_blank" rel="noreferrer">{{ p.audience.gettingStarted.ctaSecondary }}</a>
          </div>
        </div>
      </div>
    </section>

    {# Testimonials #}
    <section id="testimonials" class="container mx-auto px-4 py-12 md:py-16">
      <div class="flex items-end justify-between gap-6 flex-wrap">
        <div>
          <h2 class="text-2xl md:text-3xl font-semibold tracking-tight">{{ p.testimonials.h2 }}</h2>
          <p class="mt-2 text-slate-700 max-w-3xl">{{ p.testimonials.intro }}</p>
        </div>
      </div>
      <div class="mt-8 grid grid-cols-1 md:grid-cols-2 gap-4">
        {% for quote in p.testimonials.quotes %}
        <div class="rounded-2xl p-6 bg-white border border-slate-900/10 shadow-soft">
          <p class="text-sm text-slate-700">{{ quote.text }}</p>
          <div class="mt-3 text-sm font-semibold">— {{ quote.author }}</div>
        </div>
        {% endfor %}
      </div>
    </section>

    {# Privacy Built In #}
    <section id="privacy-built" class="container mx-auto px-4 py-12 md:py-16">
      <div class="rounded-3xl p-8 md:p-10 bg-slate-900 text-white shadow-soft">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 items-center">
          <div>
            <h2 class="text-2xl md:text-3xl font-semibold tracking-tight">{{ p.privacyBuiltIn.h2 }}</h2>
            <p class="mt-2 text-white/80">{{ p.privacyBuiltIn.intro }}</p>
            <ul class="mt-4 grid gap-2 text-sm text-white/80 list-disc pl-5">
              {% for item in p.privacyBuiltIn.items %}<li>{{ item }}</li>{% endfor %}
            </ul>
            <p class="mt-4 text-white/80">{{ p.privacyBuiltIn.outro }}</p>
          </div>
          <div class="flex flex-col sm:flex-row gap-3 md:justify-end">
            <a class="inline-flex items-center justify-center rounded-xl bg-white px-5 py-3 text-sm font-semibold text-slate-900 hover:bg-slate-100" href="{{ site.chromeStoreUrl }}" target="_blank" rel="noreferrer">{{ p.privacyBuiltIn.ctaPrimary }}</a>
            <a class="inline-flex items-center justify-center rounded-xl px-5 py-3 text-sm font-semibold text-white ring-1 ring-white/20 hover:bg-white/10" href="/privacy">{{ p.privacyBuiltIn.ctaSecondary }}</a>
          </div>
        </div>
      </div>
    </section>

    {# FAQ #}
    <section id="faq" class="container mx-auto px-4 py-12 md:py-16">
      <div class="flex items-end justify-between gap-6 flex-wrap">
        <div>
          <h2 class="text-2xl md:text-3xl font-semibold tracking-tight">{{ p.faq.h2 }}</h2>
          <p class="mt-2 text-slate-700 max-w-2xl">{{ p.faq.intro }}</p>
        </div>
      </div>
      <div class="mt-8 grid grid-cols-1 md:grid-cols-2 gap-4">
        {% for item in p.faq.items %}
        <details class="rounded-2xl p-5 bg-white border border-slate-900/10 shadow-soft">
          <summary class="cursor-pointer font-semibold">{{ item.q }}</summary>
          <p class="mt-2 text-sm text-slate-700">{{ item.a }}</p>
        </details>
        {% endfor %}
      </div>
    </section>

    {# Final CTA #}
