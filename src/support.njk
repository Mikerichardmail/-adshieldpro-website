---
layout: layouts/base.njk
lang: en
pageKey: support
permalink: /support.html
---
{% set t = i18n[lang] %}
{% set p = t.pages.support %}
{% set meta = p.meta %}

<header class="border-b border-slate-900/10 bg-white/70 backdrop-blur">
  <div class="container mx-auto px-4">
    <div class="flex h-16 items-center justify-between">
      <a class="flex items-center gap-2" href="/"><img class="h-9 w-9 rounded-xl" src="/icon.svg" alt="{{ site.name }}" /><span class="font-semibold tracking-tight">{{ site.name }}</span></a>
      <div class="flex items-center gap-3 text-sm">
        <a class="text-slate-700 hover:text-slate-900" href="/features">{{ t.nav.features }}</a>
        <a class="text-slate-700 hover:text-slate-900" href="/pricing">{{ t.nav.pricing }}</a>
        <a class="text-slate-700 hover:text-slate-900" href="/privacy">{{ t.nav.privacy }}</a>
        <div class="relative group">
          <button class="inline-flex items-center gap-1 text-slate-700 hover:text-slate-900" type="button">{{ t.nav.platform }}<span class="text-xs">▾</span></button>
          <div class="absolute left-0 top-full pt-2 hidden group-hover:block">
            <div class="min-w-56 rounded-xl border border-slate-900/10 bg-white shadow-soft p-2">
              {% for pl in t.platformLinks %}<a class="block rounded-lg px-3 py-2 text-sm text-slate-700 hover:bg-slate-900/5" href="{{ pl.href }}" target="_blank" rel="noreferrer">{{ pl.label }}</a>{% endfor %}
            </div>
          </div>
        </div>
        <a class="inline-flex items-center justify-center rounded-xl bg-slate-900 px-4 py-2 font-semibold text-white hover:bg-slate-800" href="{{ site.chromeStoreUrl }}" target="_blank" rel="noreferrer">{{ t.nav.addToChrome }}</a>
      </div>
    </div>
  </div>
</header>

<main class="container mx-auto px-4 py-10 md:py-14">
  <div class="max-w-3xl">
    <h1 class="text-3xl md:text-4xl font-semibold tracking-tight">{{ p.h1 }}</h1>
    <p class="mt-3 text-slate-700">{{ p.intro }}</p>

    <div class="mt-8 rounded-3xl p-6 md:p-8 bg-white border border-slate-900/10 shadow-soft">
      <h2 class="text-lg font-semibold">{{ p.contact.heading }}</h2>
      <div class="mt-3 grid gap-2 text-sm text-slate-700">
        <div><span class="font-semibold">Email:</span> <a class="text-slate-900 underline" href="mailto:{{ p.contact.email }}">{{ p.contact.email }}</a></div>
        <div><span class="font-semibold">Website:</span> <a class="text-slate-900 underline" href="{{ p.contact.website }}" target="_blank" rel="noreferrer">{{ p.contact.website }}</a></div>
        <div><span class="font-semibold">Response time:</span> {{ p.contact.responseTime }}</div>
      </div>

      <div class="mt-8 hr"></div>

      <h2 class="mt-8 text-lg font-semibold">{{ p.activatePro.heading }}</h2>
      <div class="mt-3 grid gap-3 text-sm text-slate-700">
        {% for step in p.activatePro.steps %}
        <div>
          <div class="font-semibold">{{ step.heading }}</div>
          <div class="mt-1">{{ step.body }}</div>
        </div>
        {% endfor %}
      </div>

      <div class="mt-8 hr"></div>

      <h2 class="mt-8 text-lg font-semibold">{{ p.troubleshooting.heading }}</h2>
      <div class="mt-3 grid gap-3 text-sm text-slate-700">
        {% for item in p.troubleshooting.items %}
        <div>
          <div class="font-semibold">{{ item.q }}</div>
          <div class="mt-1">{{ item.a }}</div>
        </div>
        {% endfor %}
      </div>

      <div class="mt-8 hr"></div>

      <h2 class="mt-8 text-lg font-semibold">{{ p.faq.heading }}</h2>
      <div class="mt-3 grid gap-3 text-sm text-slate-700">
        {% for item in p.faq.items %}
        <div>
          <div class="font-semibold">{{ item.q }}</div>
          <div class="mt-1">{{ item.a }}{% if loop.index == 2 %} See <a class="underline" href="/privacy">Privacy Policy</a>.{% endif %}{% if loop.index == 3 %} from the <a class="underline" href="/pricing">Pricing</a> page.{% endif %}</div>
        </div>
        {% endfor %}
      </div>
    </div>

    <div class="mt-6 text-sm"><a class="text-slate-700 hover:text-slate-900" href="/">{{ p.backToHome }}</a></div>
  </div>
</main>

{% include "partials/footer.njk" %}
