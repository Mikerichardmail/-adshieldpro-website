---
layout: layouts/base.njk
lang: en
pageKey: howToBlockAds
permalink: /how-to-block-ads-on-chrome.html
---
{% set t = i18n[lang] %}
{% set p = t.pages.howToBlockAds %}
{% set meta = p.meta %}

<div class="bg-grid">
  <header class="sticky top-0 z-50 border-b border-slate-900/10 bg-white/70 backdrop-blur">
    <div class="container mx-auto px-4">
      <div class="flex h-16 items-center justify-between gap-4">
        <a class="flex items-center gap-2" href="/" aria-label="Home"><img class="h-9 w-9 rounded-xl" src="/icon.svg" alt="{{ site.name }}" /><span class="font-semibold tracking-tight">{{ site.name }}</span></a>
        <nav class="hidden md:flex items-center gap-6 text-sm">
          <a class="hover:text-slate-950 text-slate-700" href="/features">{{ t.nav.features }}</a>
          <a class="hover:text-slate-950 text-slate-700" href="/pricing">{{ t.nav.pricing }}</a>
          <a class="hover:text-slate-950 text-slate-700" href="/privacy">{{ t.nav.privacy }}</a>
          <a class="hover:text-slate-950 text-slate-700" href="/support">{{ t.nav.support }}</a>
        </nav>
        <div class="flex items-center gap-3">
          <a class="inline-flex items-center justify-center rounded-xl border border-slate-900/10 px-4 py-2 text-sm font-semibold text-slate-900 hover:bg-slate-50" href="{{ site.chromeStoreUrl }}" target="_blank" rel="noreferrer">{{ t.nav.addToChrome }}</a>
          <a class="inline-flex items-center justify-center rounded-xl bg-slate-900 px-4 py-2 text-sm font-semibold text-white hover:bg-slate-800" href="/pricing">Upgrade to Pro</a>
        </div>
      </div>
    </div>
  </header>

  <main>
    <section class="container mx-auto px-4 py-12 md:py-16">
      <div class="max-w-3xl">
        <p class="text-sm font-semibold text-slate-600">{{ p.eyebrow }}</p>
        <h1 class="mt-3 text-4xl md:text-5xl font-semibold tracking-tight">{{ p.h1 }}</h1>
        
        <!-- Reading Info Bar -->
        <div class="mt-4 flex flex-wrap items-center gap-4 text-sm text-slate-500 border-y border-slate-900/5 py-3">
          <div class="flex items-center gap-1.5">
            <span>⏱️</span>
            <span>3 min read</span>
          </div>
          <div class="h-1.5 w-1.5 rounded-full bg-slate-300"></div>
          <div class="flex items-center gap-1.5">
            <span>👤</span>
            <span>By AdShield Pro Security Team</span>
          </div>
          <div class="h-1.5 w-1.5 rounded-full bg-slate-300"></div>
          <div class="flex items-center gap-1.5">
            <span>📂</span>
            <span class="font-medium text-slate-700">Guides & Tutorials</span>
          </div>
        </div>

        <p class="mt-6 text-lg text-slate-700 leading-relaxed">{{ p.intro }}</p>
      </div>

      <!-- Steps Timeline -->
      <div class="mt-12 max-w-3xl space-y-12 relative before:absolute before:left-6 before:top-2 before:bottom-2 before:w-0.5 before:bg-slate-200">
        {% for step in p.steps %}
        <div class="relative pl-14 group">
          <!-- Timeline Indicator -->
          <div class="absolute left-0 top-0 flex h-12 w-12 items-center justify-center rounded-xl bg-slate-900 text-sm font-semibold text-white shadow-soft group-hover:scale-105 transition-transform duration-200">
            0{{ loop.index }}
          </div>
          <!-- Step Card -->
          <div class="rounded-2xl p-6 bg-white border border-slate-900/10 shadow-soft group-hover:shadow-md transition-shadow duration-200">
            <h2 class="text-lg font-semibold text-slate-900">{{ step.heading }}</h2>
            <p class="mt-2 text-sm text-slate-700 leading-relaxed">{{ step.body }}</p>
            
            {% if loop.index0 == 0 %}
            <div class="mt-4">
              <a class="inline-flex items-center justify-center rounded-xl bg-slate-900 px-5 py-2.5 text-sm font-semibold text-white hover:bg-slate-800 transition-colors" href="{{ site.chromeStoreUrl }}" target="_blank" rel="noreferrer">{{ step.cta }}</a>
            </div>
            {% elif loop.index0 == 1 %}
            <p class="mt-3 text-sm text-slate-500">If you need help, see <a class="font-semibold text-slate-900 hover:underline" href="/support">{{ step.support }}</a>.</p>
            {% elif loop.index0 == 2 %}
            <p class="mt-3 text-sm text-slate-500">Learn more about controls on <a class="font-semibold text-slate-900 hover:underline" href="/features">{{ step.features }}</a>.</p>
            {% elif loop.index0 == 3 %}
            <p class="mt-3 text-sm text-slate-500">Read our <a class="font-semibold text-slate-900 hover:underline" href="/privacy">{{ step.privacy }}</a>.</p>
            {% endif %}
          </div>
        </div>
        {% endfor %}
      </div>

      <div class="mt-12 max-w-3xl rounded-3xl p-6 md:p-10 bg-white border border-slate-900/10 shadow-soft">
        <h2 class="text-2xl font-semibold tracking-tight">{{ p.related.h2 }}</h2>
        <p class="mt-2 text-slate-700">{{ p.related.body }} <a class="font-semibold text-slate-900 hover:underline" href="/how-to-stop-trackers">{{ p.related.stopTrackers }}</a> or the overview page <a class="font-semibold text-slate-900 hover:underline" href="/tracker-blocker">{{ p.related.trackerBlocker }}</a>.</p>
      </div>
    </section>

    <section class="container mx-auto px-4 pb-14">
      <div class="rounded-3xl p-6 md:p-10 bg-slate-950 text-white">
        <div class="max-w-3xl">
          <h2 class="text-2xl md:text-3xl font-semibold tracking-tight">{{ p.cta.h2 }}</h2>
          <p class="mt-2 text-white/80">{{ p.cta.body }}</p>
          <div class="mt-6 flex flex-col sm:flex-row gap-3">
            <a class="inline-flex items-center justify-center rounded-xl bg-white px-5 py-3 text-sm font-semibold text-slate-900 hover:bg-slate-100" href="{{ site.chromeStoreUrl }}" target="_blank" rel="noreferrer">{{ p.cta.ctaPrimary }}</a>
            <a class="inline-flex items-center justify-center rounded-xl px-5 py-3 text-sm font-semibold text-white ring-1 ring-white/20 hover:bg-white/10" href="/pricing">{{ p.cta.ctaSecondary }}</a>
          </div>
        </div>
      </div>
    </section>
  </main>

  {% include "partials/footer.njk" %}
</div>
