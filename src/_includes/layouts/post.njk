---
layout: layouts/base.njk
---
{% set t = i18n[lang] | default(i18n.en) %}
<div class="bg-grid">
  <header class="sticky top-0 z-50 border-b border-slate-900/10 bg-white/70 backdrop-blur">
    <div class="container mx-auto px-4">
      <div class="flex h-16 items-center justify-between gap-4">
        <a class="flex items-center gap-2" href="/" aria-label="Home"><img class="h-9 w-9 rounded-xl" src="/icon.svg" alt="{{ site.name }}" /><span class="font-semibold tracking-tight">{{ site.name }}</span></a>
        <nav class="hidden md:flex items-center gap-6 text-sm">
          <a class="hover:text-slate-950 text-slate-700 font-medium" href="/features">{{ t.nav.features }}</a>
          <a class="hover:text-slate-950 text-slate-700 font-medium" href="/pricing">{{ t.nav.pricing }}</a>
          <a class="hover:text-slate-950 text-slate-700 font-medium" href="/blog">Blog</a>
          <a class="hover:text-slate-950 text-slate-700 font-medium" href="/privacy">{{ t.nav.privacy }}</a>
          <a class="hover:text-slate-950 text-slate-700 font-medium" href="/support">{{ t.nav.support }}</a>
        </nav>
        <div class="flex items-center gap-3">
          <a class="inline-flex items-center justify-center rounded-xl border border-slate-900/10 px-4 py-2 text-sm font-semibold text-slate-900 hover:bg-slate-50" href="{{ site.chromeStoreUrl }}" target="_blank" rel="noreferrer">{{ t.nav.addToChrome }}</a>
          <a class="inline-flex items-center justify-center rounded-xl bg-slate-900 px-4 py-2 text-sm font-semibold text-white hover:bg-slate-800" href="/pricing">Upgrade to Pro</a>
        </div>
      </div>
    </div>
  </header>

  <main class="container mx-auto px-4 py-12 md:py-16">
    <article class="max-w-3xl mx-auto bg-white rounded-3xl p-6 md:p-10 border border-slate-900/10 shadow-soft">
      <!-- Category & Date -->
      <div class="flex items-center gap-2 text-sm">
        <span class="inline-flex items-center gap-1.5 rounded-full px-3 py-1 text-xs badge text-slate-700 font-semibold bg-slate-100">{{ category | default("Guides") }}</span>
        <span class="text-slate-400">•</span>
        <time class="text-slate-500 font-medium" datetime="{{ date }}">{{ date }}</time>
        {% if reading_time %}
        <span class="text-slate-400">•</span>
        <span class="text-slate-500 font-medium">{{ reading_time }}</span>
        {% endif %}
      </div>

      <!-- Title -->
      <h1 class="mt-6 text-3xl sm:text-4xl md:text-5xl font-semibold tracking-tight text-slate-900 leading-tight">{{ title }}</h1>

      <!-- Author -->
      <div class="mt-4 flex items-center gap-3 border-b border-slate-900/5 pb-6">
        <div class="h-9 w-9 rounded-full bg-slate-100 flex items-center justify-center font-semibold text-slate-700 text-sm">
          AP
        </div>
        <div>
          <div class="text-sm font-semibold text-slate-900">{{ author | default("AdShield Pro Team") }}</div>
          <div class="text-xs text-slate-500">Security & Privacy Specialists</div>
        </div>
      </div>

      <!-- Quick Summary Box -->
      <div class="rounded-2xl p-5 bg-slate-50 border border-slate-900/5 mt-8">
        <h2 class="text-sm font-semibold text-slate-900 flex items-center gap-1.5">
          <span>💡</span> Quick Summary
        </h2>
        <p class="mt-2 text-sm text-slate-700 leading-relaxed">{{ description }}</p>
      </div>

      <!-- Content -->
      <div class="mt-8 text-slate-700 leading-relaxed space-y-6">
        {{ content | safe }}
      </div>

      <!-- In-Article Call to Action -->
      <div class="mt-12 border-t border-slate-900/5 pt-8">
        <div class="rounded-2xl p-6 bg-slate-50 border border-slate-900/5 flex flex-col sm:flex-row items-center justify-between gap-6">
          <div>
            <h3 class="font-semibold text-slate-900">Stop seeing ads and tracking scripts today</h3>
            <p class="mt-1 text-sm text-slate-600">AdShield Pro is free, Manifest V3 compliant, and runs 100% offline.</p>
          </div>
          <a class="inline-flex items-center justify-center rounded-xl bg-slate-900 px-5 py-3 text-sm font-semibold text-white hover:bg-slate-800 transition-colors shrink-0" href="{{ site.chromeStoreUrl }}" target="_blank" rel="noreferrer">
            Add to Chrome — Free
          </a>
        </div>
      </div>
    </article>

    <!-- Related Articles Section -->
    <section class="max-w-3xl mx-auto mt-12 border-t border-slate-900/5 pt-10">
      <h2 class="text-xl font-semibold text-slate-900 tracking-tight">Related Articles</h2>
      <p class="mt-1 text-sm text-slate-500">More guides and insights on online privacy, browser speed, and security.</p>
      
      <div class="mt-6 grid grid-cols-1 sm:grid-cols-2 gap-4">
        {% for otherPost in collections.posts | reverse %}
          {% if otherPost.url != page.url and loop.index0 < 3 %}
            <article class="rounded-2xl p-5 bg-white border border-slate-900/10 shadow-soft hover:shadow-md transition-shadow duration-200 flex flex-col justify-between">
              <div>
                <span class="inline-flex items-center rounded-full px-2.5 py-0.5 text-xs badge text-slate-700 font-semibold bg-slate-100">{{ otherPost.data.category | default("Guides") }}</span>
                <h3 class="mt-3 text-sm font-semibold text-slate-900 leading-snug">
                  <a class="hover:underline" href="{{ otherPost.url }}">{{ otherPost.data.title }}</a>
                </h3>
              </div>
              <a class="mt-4 text-xs font-semibold text-slate-900 hover:underline inline-flex items-center gap-1" href="{{ otherPost.url }}">
                Read Article <span>→</span>
              </a>
            </article>
          {% endif %}
        {% endfor %}
      </div>
    </section>

    <!-- Back Navigation -->
    <div class="max-w-3xl mx-auto mt-8 flex justify-between items-center text-sm">
      <a class="font-semibold text-slate-900 hover:underline" href="/blog">← Back to Blog</a>
      <a class="font-semibold text-slate-900 hover:underline" href="/">Back to Home</a>
    </div>
  </main>

  {% include "partials/footer.njk" %}
</div>
