{% set t = i18n[lang] %}
{% set f = t.footer %}
<footer class="border-t border-slate-900/10 bg-white/60 backdrop-blur">
  <div class="container mx-auto px-4 py-10">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
      <div>
        <a class="inline-flex items-center gap-2" href="/" aria-label="Home">
          <img class="h-9 w-9 rounded-xl" src="/icon.svg" alt="{{ site.name }}" />
          <span class="font-semibold tracking-tight">{{ site.name }}</span>
        </a>
        <p class="mt-3 text-sm text-slate-600">{{ f.tagline }}</p>
        <div class="mt-4 grid gap-2 text-sm">
          <a class="text-slate-700 hover:text-slate-900" href="mailto:{{ f.email }}">{{ f.email }}</a>
          <a class="text-slate-700 hover:text-slate-900" href="{{ f.upgradeHref }}" target="_blank" rel="noreferrer">{{ f.upgradeLabel }}</a>
        </div>
      </div>

      {% for key, section in f.sections %}
      <div>
        <div class="text-sm font-semibold text-slate-900">{{ section.heading }}</div>
        <div class="mt-3 grid gap-2 text-sm">
          {% for link in section.links %}
          <a class="text-slate-700 hover:text-slate-900" href="{{ link.href }}"{% if link.external %} target="_blank" rel="noreferrer"{% endif %}>{{ link.label }}</a>
          {% endfor %}
        </div>
      </div>
      {% endfor %}
    </div>

    <div class="mt-10 flex flex-col md:flex-row gap-3 md:items-center md:justify-between text-sm text-slate-600">
      <div>© <span id="year"></span> {{ f.copyright }}</div>
      <div class="flex flex-wrap gap-x-4 gap-y-2">
        {% for link in f.bottomLinks %}
        <a class="text-slate-700 hover:text-slate-900" href="{{ link.href }}">{{ link.label }}</a>
        {% endfor %}
      </div>
    </div>
  </div>
</footer>
