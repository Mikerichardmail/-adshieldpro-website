---
layout: layouts/base.njk
lang: en
pageKey: adBlocker
permalink: /ad-blocker.html
---
{% set t = i18n[lang] %}
{% set p = t.pages.adBlocker %}
{% set meta = p.meta %}

<div class="bg-grid">
  {% set headerCtaUpgrade = false %}
  <header class="sticky top-0 z-50 border-b border-slate-900/10 bg-white/70 backdrop-blur">
    <div class="container mx-auto px-4">
      <div class="flex h-16 items-center justify-between gap-4">
        <a class="flex items-center gap-2" href="/" aria-label="Home"><img class="h-9 w-9 rounded-xl" src="/icon.svg" alt="{{ site.name }}" /><span class="font-semibold tracking-tight">{{ site.name }}</span></a>
        <nav class="hidden md:flex items-center gap-6 text-sm">
          <a class="hover:text-slate-950 text-slate-700" href="/features">{{ t.nav.features }}</a>
          <a class="hover:text-slate-950 text-slate-700" href="/pricing">{{ t.nav.pricing }}</a>
          <a class="hover:text-slate-950 text-slate-700" href="/privacy">{{ t.nav.privacy }}</a>
          <a class="hover:text-slate-950 text-slate-700" href="/support">{{ t.nav.support }}</a>
        </nav>
        <div class="flex items-center gap-3">
          <a class="inline-flex items-center justify-center rounded-xl border border-slate-900/10 px-4 py-2 text-sm font-semibold text-slate-900 hover:bg-slate-50" href="{{ site.chromeStoreUrl }}" target="_blank" rel="noreferrer">{{ t.nav.addToChrome }}</a>
          <a class="inline-flex items-center justify-center rounded-xl bg-slate-900 px-4 py-2 text-sm font-semibold text-white hover:bg-slate-800" href="/pricing">Upgrade to Pro</a>
        </div>
      </div>
    </div>
  </header>

  <main>
    <section class="container mx-auto px-4 py-12 md:py-16">
      <div class="max-w-3xl">
        <p class="text-sm font-semibold text-slate-600">{{ p.eyebrow }}</p>
        <h1 class="mt-3 text-4xl md:text-5xl font-semibold tracking-tight">{{ p.h1 }}</h1>
        <p class="mt-4 text-lg text-slate-700">{{ p.intro }}</p>
        <div class="mt-8 flex flex-col sm:flex-row gap-3">
          <a class="inline-flex items-center justify-center rounded-xl bg-slate-900 px-5 py-3 text-sm font-semibold text-white hover:bg-slate-800" href="{{ site.chromeStoreUrl }}" target="_blank" rel="noreferrer">{{ p.ctaPrimary }}</a>
          <a class="inline-flex items-center justify-center rounded-xl border border-slate-900/10 px-5 py-3 text-sm font-semibold text-slate-900 hover:bg-slate-50" href="/features">{{ p.ctaSecondary }}</a>
        </div>
      </div>

      <div class="mt-10 grid grid-cols-1 md:grid-cols-2 gap-4">
        <div class="rounded-2xl p-6 card shadow-soft">
          <div class="text-sm font-semibold">{{ p.whatItBlocks.heading }}</div>
          <ul class="mt-3 grid gap-2 text-sm text-slate-700 list-disc pl-5">
            {% for item in p.whatItBlocks.items %}<li>{{ item }}</li>{% endfor %}
          </ul>
        </div>
        <div class="rounded-2xl p-6 card shadow-soft">
          <div class="text-sm font-semibold">{{ p.whyDifferent.heading }}</div>
          <p class="mt-2 text-sm text-slate-700">{{ p.whyDifferent.body }} Learn more about our <a class="font-semibold text-slate-900 hover:underline" href="/privacy">{{ p.whyDifferent.privacyLink }}</a> and how we keep things offline-first.</p>
          <p class="mt-3 text-sm text-slate-700">Need a quick setup? Follow <a class="font-semibold text-slate-900 hover:underline" href="/how-to-block-ads-on-chrome">{{ p.whyDifferent.howToLink }}</a>. If a page breaks, see <a class="font-semibold text-slate-900 hover:underline" href="/how-to-fix-sites-after-blocking">{{ p.whyDifferent.fixLink }}</a>.</p>
        </div>
      </div>

      <div class="mt-10 rounded-3xl p-6 md:p-10 bg-white border border-slate-900/10 shadow-soft">
        <h2 class="text-2xl md:text-3xl font-semibold tracking-tight">{{ p.moreControl.h2 }}</h2>
        <p class="mt-2 text-slate-700">{{ p.moreControl.body }} See details on the <a class="font-semibold text-slate-900 hover:underline" href="/pricing">{{ p.moreControl.pricingLink }}</a>.</p>
      </div>
    </section>

    <section class="container mx-auto px-4 pb-14">
      <div class="rounded-3xl p-6 md:p-10 bg-slate-950 text-white">
        <div class="max-w-3xl">
          <h2 class="text-2xl md:text-3xl font-semibold tracking-tight">{{ p.cta.h2 }}</h2>
          <p class="mt-2 text-white/80">{{ p.cta.body }}</p>
          <div class="mt-6 flex flex-col sm:flex-row gap-3">
            <a class="inline-flex items-center justify-center rounded-xl bg-white px-5 py-3 text-sm font-semibold text-slate-900 hover:bg-slate-100" href="{{ site.chromeStoreUrl }}" target="_blank" rel="noreferrer">{{ p.cta.ctaPrimary }}</a>
            <a class="inline-flex items-center justify-center rounded-xl px-5 py-3 text-sm font-semibold text-white ring-1 ring-white/20 hover:bg-white/10" href="/support">{{ p.cta.ctaSecondary }}</a>
          </div>
        </div>
      </div>
    </section>
  </main>

  {% include "partials/footer.njk" %}
</div>
