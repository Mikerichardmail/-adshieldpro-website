{
  "name": "adshieldpro-website",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "build:css": "tailwindcss -i ./src/styles.css -o ./site/styles.css --minify",
    "watch:css": "tailwindcss -i ./src/styles.css -o ./site/styles.css --watch",
    "dev": "concurrently \"npm run watch:css\" \"npx @11ty/eleventy --serve\"",
    "build": "npm run build:css && npx @11ty/eleventy"
  },
  "devDependencies": {
    "@11ty/eleventy": "^2.0.1",
    "concurrently": "^8.2.2",
    "tailwindcss": "^3.4.1"
  }
}
